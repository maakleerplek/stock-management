# Caddyfile for Stock Management System + InvenTree
# Based on Standard InvenTree Caddyfile + Custom Stock App Additions

# Global options
{
	default_sni {$SITE_IP}
}

# Logging configuration for Caddy
(log_common) {
	log {
		output file /var/log/caddy/{args[0]}.access.log
	}
}

# CORS headers for static and media files served by InvenTree
(cors-headers) {
	header Allow GET,HEAD,OPTIONS
	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods GET,HEAD,OPTIONS
	header Access-Control-Allow-Headers Authorization,Content-Type,User-Agent

	@cors_preflight{args[0]} method OPTIONS

	handle @cors_preflight{args[0]} {
		respond "" 204
	}
}

# Common settings (compression + body size)
(common) {
	encode gzip
	request_body {
		max_size 100MB
	}
}

# CORS headers for the Stock App API endpoints
(api-cors) {
	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type, Authorization"
}

# =============================================================================
# INVENTREE — HTTPS only on port 8443
# =============================================================================

https://{$SITE_IP}:{$INVENTREE_PORT:8443}, https://inventree.localhost:{$INVENTREE_PORT:8443} {
	tls internal
	import log_common inventree

	encode gzip

	request_body {
		max_size 100MB
	}

	# Handle static request files
	handle_path /static/* {
		import cors-headers static

		root * /var/www/static
		file_server
	}

	# Handle media request files
	handle_path /media/* {
		import cors-headers media

		root * /var/www/media
		file_server

		# Force download of media files (for security)
		header Content-Disposition attachment

		# Authentication is handled by the forward_auth directive
		forward_auth {$INVENTREE_SERVER:"http://inventree-server:8000"} {
			uri /auth/
		}
	}

	# All other requests are proxied to the InvenTree server
	reverse_proxy {$INVENTREE_SERVER:"http://inventree-server:8000"} {
		header_down -X-Frame-Options
		header_down -Content-Security-Policy
	}
}

# =============================================================================
# CUSTOM STOCK MANAGEMENT APP — HTTPS only on port 8082
# =============================================================================

:{$STOCK_PORT} {
	tls internal
	import log_common stock
	import common

	# Backend API — OPTIONS preflight answered at site level (named matchers
	# must be defined here, not inside handle_path blocks)
	@api_preflight {
		path /api/*
		method OPTIONS
	}
	handle @api_preflight {
		import api-cors
		respond "" 204
	}

	handle_path /api/* {
		import api-cors
		reverse_proxy backend:8001
	}

	# InvenTree proxy — served at /inventree/ to avoid cross-origin issues
	handle_path /inventree/static/* {
		uri strip_prefix /inventree
		root * /var/www/static
		file_server
	}

	handle_path /inventree/media/* {
		uri strip_prefix /inventree
		root * /var/www/media
		file_server
	}

	handle_path /inventree/* {
		uri strip_prefix /inventree
		reverse_proxy inventree-server:8000 {
			header_up Host {http.request.host}
			header_down -X-Frame-Options
			header_down -Content-Security-Policy
		}
	}

	# Redirect /inventree → /inventree/
	handle /inventree {
		redir /inventree/ permanent
	}

	# Frontend (default)
	handle {
		reverse_proxy frontend:80
	}
}

# =============================================================================
# INTERNAL MEDIA SERVER (backend image proxy — no auth, internal only)
# =============================================================================

:8081 {
	import log_common internal-media

	# Serve media files without authentication
	handle_path /media/* {
		root * /var/www/media
		file_server
	}

	# Serve static files without authentication
	handle_path /static/* {
		root * /var/www/static
		file_server
	}

	# Health check
	handle /health {
		respond "ok" 200
	}
}
