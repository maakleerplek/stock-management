# =============================================================================
# INVENTREE CORE SETTINGS
# =============================================================================
COMPOSE_PROJECT_NAME=inventree
INVENTREE_TAG=stable
# InvenTree server URL - update this to match your server URL
INVENTREE_SITE_URL="https://inventree.localhost"
INVENTREE_EXT_VOLUME=./inventree-data
INVENTREE_LOG_LEVEL=WARNING
INVENTREE_PLUGINS_ENABLED=True
INVENTREE_AUTO_UPDATE=True

# =============================================================================
# INVENTREE DATABASE
# =============================================================================
# DO NOT CHANGE THESE SETTINGS (unless you really know what you are doing)
INVENTREE_DB_ENGINE=postgresql
INVENTREE_DB_NAME=inventree
INVENTREE_DB_HOST=inventree-db
INVENTREE_DB_PORT=5432
# Database credentials - CHANGE THESE!
INVENTREE_DB_USER=pguser
INVENTREE_DB_PASSWORD=CHANGE_ME

# =============================================================================
# INVENTREE CACHE
# =============================================================================
INVENTREE_CACHE_ENABLED=True
INVENTREE_CACHE_HOST=inventree-cache
INVENTREE_CACHE_PORT=6379

# =============================================================================
# INVENTREE ADMIN ACCOUNT
# =============================================================================
#INVENTREE_ADMIN_USER=
#INVENTREE_ADMIN_PASSWORD=
#INVENTREE_ADMIN_EMAIL=

# =============================================================================
# INVENTREE SERVER & PROXY SETTINGS
# =============================================================================
INVENTREE_GUNICORN_TIMEOUT=90
INVENTREE_USE_X_FORWARDED_HOST=True
INVENTREE_USE_X_FORWARDED_PORT=True
INVENTREE_USE_X_FORWARDED_PROTO=True
# Allow unauthenticated access to media files (required for image proxy)
INVENTREE_MEDIA_AUTH_ENABLED=False

# =============================================================================
# STOCK MANAGEMENT APP - BACKEND CONFIGURATION
# =============================================================================
# InvenTree API token (generate from InvenTree: Settings -> API Tokens)
INVENTREE_TOKEN=your-inventree-api-token-here
# CORS allowed origins (comma-separated, used by backend)
CORS_ORIGINS=*

# =============================================================================
# STOCK MANAGEMENT APP - FRONTEND CONFIGURATION
# =============================================================================
VITE_BACKEND_URL=http://localhost:8001
VITE_VOLUNTEER_PASSWORD=volunteer

# Pricing - Extra Services
VITE_LASER_PRICE_PER_MIN=0.50
VITE_PRINT_PRICE_PER_GRAM=0.10
VITE_CURRENCY=EUR
# Wero (EPC QR) Payment Integration
VITE_PAYMENT_NAME="your-account-name-here"
VITE_PAYMENT_IBAN="your-iban-here"

# Footer Links Configuration
VITE_DOCS_URL="https://docs.inventree.org/en/stable/"
VITE_FEEDBACK_URL="https://forms.office.com/Pages/ResponsePage.aspx?"
VITE_GITHUB_URL="https://github.com/maakleerplek/stock-management"

# =============================================================================
# NETWORK & PRODUCTION SETTINGS (Nginx Proxy Manager / Caddy)
# =============================================================================
# Network IP for accessing from other devices (mobile, etc.) put ipv4 here
SITE_IP=192.168.1.100
# Stock Management App URL
STOCK_SITE_URL=https://stock.localhost
# Ports exposed by Caddy (NPM will proxy to these)
STOCK_PORT=8080
INVENTREE_PORT=8081
# Public URL for InvenTree (what users see in browser/iframe)
INVENTREE_PUBLIC_URL=https://inventree.yourdomain.com
# Allow InvenTree to be accessed from multiple hosts
INVENTREE_ALLOWED_HOSTS=inventree.localhost,localhost
# Disable SITE_URL checking (for local multi-access development)
INVENTREE_STRICT_URL_CHECK=False
# Domain used for Host header spoofing (must match INVENTREE_SITE_URL hostname)
SITE_DOMAIN=inventree.localhost
